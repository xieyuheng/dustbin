(module meta)

(define-type env-t (hash-t symbol-t value-t))

(claim empty-env (-> env-t))
(define (empty-env) (@hash))

(claim env-names (-> env-t (list-t symbol-t)))
(define (env-names env) (hash-keys env))

(claim env-has? (-> symbol-t env-t bool-t))
(define (env-has? name env) (hash-has? name env))

(claim env-lookup-value (-> symbol-t env-t value-t))
(define (env-lookup-value name env) (hash-get name env))

(claim env-put (-> symbol-t value-t env-t env-t))
(define (env-put name value env) (hash-put name value env))

(claim env-put-many (-> (list-t symbol-t) (list-t value-t) env-t env-t))
(define (env-put-many names values env)
  (hash-put-entries (list-map-zip make-hash-entry names values) env))

(define-test env-test
  (= env (empty-env))
  (assert-not (env-has? 'x env))
  (= env (env-put-many ['x 'y] [(int-value 1) (int-value 2)] env))
  (assert (env-has? 'x env))
  (assert (env-has? 'y env))
  (assert-equal (int-value 1) (env-lookup-value 'x env))
  (assert-equal (int-value 2) (env-lookup-value 'y env)))
