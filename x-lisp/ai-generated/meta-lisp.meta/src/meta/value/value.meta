(module meta)

(define-data value-t
  (symbol-value (content symbol-t))
  (keyword-value (content keyword-t))
  (string-value (content string-t))
  (int-value (content int-t))
  (float-value (content float-t))
  (bool-value (content bool-t))
  (void-value (content void-t))
  (list-value (elements (list-t value-t)))
  (record-value (attributes (hash-t keyword-t value-t)))
  (closure-value (mod mod-t) (env env-t)
                 (parameters (list-t symbol-t)) (body exp-t))
  (curry-value (target value-t) (arity int-t) (args (list-t value-t)))
  ;; Type values used by the bootstrap type checker.
  (atom-type-value (name symbol-t))
  (var-type-value (name symbol-t) (serial int-t))
  (arrow-type-value (arg-types (list-t value-t)) (ret-type value-t))
  (list-type-value (element-type value-t))
  (set-type-value (element-type value-t))
  (hash-type-value (key-type value-t) (value-type value-t))
  (interface-type-value (attribute-types (hash-t keyword-t value-t)))
  (extend-interface-type-value (base-type value-t)
                               (attribute-types (hash-t keyword-t value-t)))
  (polymorphic-type-value (var-types (list-t value-t))
                          (body-type value-t))
  (type-type-value)
  (any-type-value)
  (definition-value (definition definition-t))
  (file-value (file file-t)))
