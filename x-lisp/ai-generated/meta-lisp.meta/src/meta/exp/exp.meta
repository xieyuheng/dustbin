(module meta)

(define-data exp-t
  (symbol-exp (content symbol-t) (location source-location-t))
  (keyword-exp (content keyword-t) (location source-location-t))
  (string-exp (content string-t) (location source-location-t))
  (int-exp (content int-t) (location source-location-t))
  (float-exp (content float-t) (location source-location-t))
  (var-exp (name symbol-t) (location source-location-t))
  (qualified-var-exp (mod-name string-t) (name symbol-t)
                     (location source-location-t))
  (apply-exp (target exp-t) (args (list-t exp-t))
             (location source-location-t))
  (lambda-exp (parameters (list-t symbol-t)) (body exp-t)
              (location source-location-t))
  (let1-exp (name symbol-t) (rhs exp-t) (body exp-t)
            (location source-location-t))
  (begin1-exp (head exp-t) (body exp-t)
              (location source-location-t))
  (begin-sugar-exp (sequence (list-t exp-t)) (location source-location-t))
  (assign-sugar-exp (name symbol-t) (rhs exp-t) (location source-location-t))
  (if-exp (condition exp-t) (consequent exp-t) (alternative exp-t)
          (location source-location-t))
  (when-exp (condition exp-t) (consequent exp-t)
            (location source-location-t))
  (unless-exp (condition exp-t) (alternative exp-t)
              (location source-location-t))
  (and-exp (exps (list-t exp-t)) (location source-location-t))
  (or-exp (exps (list-t exp-t)) (location source-location-t))
  (cond-exp (clauses (list-t cond-clause-t)) (location source-location-t))
  (list-exp (elements (list-t exp-t)) (location source-location-t))
  (set-exp (elements (list-t exp-t)) (location source-location-t))
  (record-exp (attributes (hash-t keyword-t exp-t))
              (location source-location-t))
  (hash-exp (entries (list-t (interface :key exp-t :value exp-t)))
            (location source-location-t))
  (quote-exp (sexp located-sexp-t) (location source-location-t))
  (arrow-exp (arg-types (list-t exp-t)) (ret-type exp-t)
             (location source-location-t))
  (interface-exp (attribute-types (hash-t keyword-t exp-t))
                 (location source-location-t))
  (extend-interface-exp (base-type exp-t)
                        (attribute-types (hash-t keyword-t exp-t))
                        (location source-location-t))
  (extend-exp (base exp-t) (attributes (hash-t keyword-t exp-t))
              (location source-location-t))
  (update-exp (base exp-t) (attributes (hash-t keyword-t exp-t))
              (location source-location-t))
  (update-mut-exp (base exp-t) (attributes (hash-t keyword-t exp-t))
                  (location source-location-t))
  (the-exp (type exp-t) (exp exp-t) (location source-location-t))
  (polymorphic-exp (parameters (list-t symbol-t)) (body exp-t)
                   (location source-location-t))
  (match-exp (targets (list-t exp-t))
             (clauses (list-t match-clause-t))
             (location source-location-t)))

(define-interface cond-clause-t
  :question exp-t
  :answer exp-t
  :location source-location-t)

(define-interface match-clause-t
  :patterns (list-t exp-t)
  :body exp-t
  :location source-location-t)
