(module meta)

(claim evaluate (-> mod-t env-t exp-t value-t))

(define (evaluate mod env exp)
  (match exp
    ((symbol-exp content location) (symbol-value content))
    ((keyword-exp content location) (keyword-value content))
    ((string-exp content location) (string-value content))
    ((int-exp content location) (int-value content))
    ((float-exp content location) (float-value content))
    ((var-exp name location)
     (if (env-has? name env)
       (env-lookup-value name env)
       (match (mod-get-definition-maybe mod name)
         ((just definition) (definition-meaning definition))
         (nothing (error "(evaluate) undefined variable")))))
    ((qualified-var-exp mod-name name location)
     (if (equal? mod-name (symbol-to-string (:name mod)))
       (match (mod-get-definition-maybe mod name)
         ((just definition) (definition-meaning definition))
         (nothing (error "(evaluate) undefined qualified variable")))
       (error "(evaluate) unknown module prefix")))
    ((apply-exp target args location)
     (apply (evaluate mod env target)
       (list-map (evaluate mod env) args)))
    ((lambda-exp parameters body location)
     (closure-value mod env parameters body))
    ((let1-exp name rhs body location)
     (evaluate mod (env-put name (evaluate mod env rhs) env) body))
    ((begin1-exp head body location)
     (begin (evaluate mod env head)
            (evaluate mod env body)))
    ((begin-sugar-exp sequence location)
     (evaluate-sequence mod env sequence))
    ;; (assign-sugar-exp (name symbol-t) (rhs exp-t) (location source-location-t))
    ((if-exp condition consequent alternative location)
     (if (is-truthy (evaluate mod env condition))
       (evaluate mod env consequent)
       (evaluate mod env alternative)))
    ((when-exp condition consequent location)
     (if (is-truthy (evaluate mod env condition))
       (evaluate mod env consequent)
       (void-value void)))
    ((unless-exp condition alternative location)
     (if (is-truthy (evaluate mod env condition))
       (void-value void)
       (evaluate mod env alternative)))
    ((and-exp exps location)
     (evaluate-and mod env exps))
    ((or-exp exps location)
     (evaluate-or mod env exps))
    ((cond-exp clauses location)
     (evaluate-cond mod env clauses))
    ((list-exp elements location)
     (list-value (list-map (evaluate mod env) elements)))
    ;; (set-exp (elements (list-t exp-t)) (location source-location-t))
    ((record-exp attributes location)
     (record-value (hash-map-value (evaluate mod env) attributes)))
    ;; (hash-exp (entries (list-t (interface :key exp-t :value exp-t)))
    ;;           (location source-location-t))
    ;; (quote-exp (sexp located-sexp-t) (location source-location-t))
    ;; (arrow-exp (arg-types (list-t exp-t)) (ret-type exp-t)
    ;;            (location source-location-t))
    ;; (interface-exp (attribute-types (hash-t keyword-t exp-t))
    ;;                (location source-location-t))
    ;; (extend-interface-exp (base-type exp-t)
    ;;                       (attribute-types (hash-t keyword-t exp-t))
    ;;                       (location source-location-t))
    ((extend-exp base attributes location)
     (evaluate-extend mod env base attributes))
    ((update-exp base attributes location)
     (evaluate-update mod env base attributes))
    ((update-mut-exp base attributes location)
     (evaluate-update-mut mod env base attributes))
    ((the-exp type exp location)
     (evaluate mod env exp))
    ;; (polymorphic-exp (parameters (list-t symbol-t)) (body exp-t)
    ;;                  (location source-location-t))
    ;; (match-exp (targets (list-t exp-t))
    ;;            (clauses (list-t match-clause-t))
    ;;            (location source-location-t))
    (else (void-value void))))

(claim is-truthy (-> value-t bool-t))

(define (is-truthy value)
  (match value
    ((bool-value false) false)
    (else true)))

(claim evaluate-sequence (-> mod-t env-t (list-t exp-t) value-t))

(define (evaluate-sequence mod env sequence)
  (if (equal? 0 (list-length sequence))
    (void-value void)
    (if (equal? 1 (list-length sequence))
      (evaluate mod env (car sequence))
      (begin
        (evaluate mod env (car sequence))
        (evaluate-sequence mod env (cdr sequence))))))

(claim evaluate-and (-> mod-t env-t (list-t exp-t) value-t))

(define (evaluate-and mod env exps)
  (if (equal? 0 (list-length exps))
    (bool-value true)
    (let ((value (evaluate mod env (car exps))))
      (if (is-truthy value)
        (if (equal? 1 (list-length exps))
          value
          (evaluate-and mod env (cdr exps)))
        value))))

(claim evaluate-or (-> mod-t env-t (list-t exp-t) value-t))

(define (evaluate-or mod env exps)
  (if (equal? 0 (list-length exps))
    (bool-value false)
    (let ((value (evaluate mod env (car exps))))
      (if (is-truthy value)
        value
        (if (equal? 1 (list-length exps))
          value
          (evaluate-or mod env (cdr exps)))))))

(claim evaluate-cond
  (-> mod-t env-t (list-t (interface :question exp-t :answer exp-t))
      value-t))

(define (evaluate-cond mod env clauses)
  (if (equal? 0 (list-length clauses))
    (void-value void)
    (let ((clause (car clauses)))
      (if (is-truthy (evaluate mod env (:question clause)))
        (evaluate mod env (:answer clause))
        (evaluate-cond mod env (cdr clauses))))))

(claim evaluate-extend
  (-> mod-t env-t exp-t (hash-t keyword-t exp-t)
      value-t))

(define (evaluate-extend mod env base-exp attributes-exp)
  (let ((base (evaluate mod env base-exp)))
    (match base
      ((record-value base-attributes)
       (let ((attributes (hash-map-value (evaluate mod env) attributes-exp)))
         (record-value (hash-append base-attributes attributes))))
      (else (error "(evaluate) (extend) expects record base")))))

(claim evaluate-update
  (-> mod-t env-t exp-t (hash-t keyword-t exp-t)
      value-t))

(define (evaluate-update mod env base-exp attributes-exp)
  (let ((base (evaluate mod env base-exp)))
    (match base
      ((record-value base-attributes)
       (let ((attributes (hash-map-value (evaluate mod env) attributes-exp)))
         (if (record-has-keys? base-attributes (hash-keys attributes))
           (record-value (hash-append base-attributes attributes))
           (error "(evaluate) (update) missing key in base record"))))
      (else (error "(evaluate) (update) expects record base")))))

(claim evaluate-update-mut
  (-> mod-t env-t exp-t (hash-t keyword-t exp-t)
      value-t))

(define (evaluate-update-mut mod env base-exp attributes-exp)
  (let ((base (evaluate mod env base-exp)))
    (match base
      ((record-value base-attributes)
       (let ((attributes (hash-map-value (evaluate mod env) attributes-exp)))
         (if (record-has-keys? base-attributes (hash-keys attributes))
           (begin
             (hash-each (lambda (key value) (hash-put! key value base-attributes))
                        attributes)
             base)
           (error "(evaluate) (update!) missing key in base record"))))
      (else (error "(evaluate) (update!) expects record base")))))

(claim record-has-keys? (-> (hash-t keyword-t value-t) (list-t keyword-t) bool-t))

(define (record-has-keys? attributes keys)
  (if (equal? 0 (list-length keys))
    true
    (and (hash-has? (car keys) attributes)
         (record-has-keys? attributes (cdr keys)))))
